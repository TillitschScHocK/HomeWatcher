# ── VPN / Network ────────────────────────────────────────────────────────────
# Your local LAN subnet that should remain reachable without going through VPN
LAN_SUBNET=192.168.0.0/16

# ── Web UI ───────────────────────────────────────────────────────────────────
# Port on which the UI is exposed on the host
UI_PORT=1966

# ── IPTV-Restream Frontend build args ────────────────────────────────────────
# Delay (in seconds) added to the HLS stream for synchronisation
VITE_STREAM_DELAY=18
# Delay (in seconds) added when using the built-in stream proxy
VITE_STREAM_PROXY_DELAY=30

# Optional: override if the backend is on a different host
# VITE_BACKEND_URL=http://192.168.1.100:1966

# ── Watchtower ────────────────────────────────────────────────────────────────
# Remove old images after a successful update
WATCHTOWER_CLEANUP=true

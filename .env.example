# ── IPTV Provider ──────────────────────────────────────────────────────────────
# Full URL to your M3U playlist
M3U_URL=http://your-provider.example/playlist.m3u8

# Full URL to your XMLTV EPG feed
EPG_URL=http://your-provider.example/epg.xml

# ── Web UI ─────────────────────────────────────────────────────────────────────
# Port on which the web UI is exposed on the host
UI_PORT=1966

# ── Watchtower ─────────────────────────────────────────────────────────────────
# Watchtower cleanup policy (true = remove old images after update)
WATCHTOWER_CLEANUP=true
